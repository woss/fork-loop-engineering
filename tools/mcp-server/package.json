{
  "name": "@cobusgreyling/loop-mcp-server",
  "version": "1.1.0",
  "description": "MCP server for loop-engineering — exposes patterns, skills, state, and audit tools as runtime-queryable resources for AI agents",
  "type": "module",
  "bin": {
    "loop-mcp-server": "dist/index.js"
  },
  "files": [
