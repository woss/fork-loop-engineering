  "author": "Cobus Greyling",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cobusgreyling/loop-engineering.git",
    "directory": "tools/mcp-server"
  },
  "homepage": "https://cobusgreyling.github.io/loop-engineering/",
  "bugs": {
    "url": "https://github.com/cobusgreyling/loop-engineering/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@cobusgreyling/loop-audit": "file:../loop-audit",
    "@cobusgreyling/loop-context": "file:../loop-context",
    "@cobusgreyling/loop-gate": "file:../loop-gate",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "minimatch": "^10.2.5",
    "yaml": "^2.8.0",
    "zod": "^3.25 || ^4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0"
  }
