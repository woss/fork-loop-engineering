    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test test/server.test.mjs",
    "prepublishOnly": "npm test",
    "start": "node dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "loop-engineering",
    "mcp",
    "model-context-protocol",
    "ai-agents",
